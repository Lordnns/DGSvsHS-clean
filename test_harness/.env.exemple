# Proxmox SSH credentials — used by record_run.py to fetch cgroup + tap stats.
PROXMOX_PASSWORD="YOUR_PASSWORD_HERE"
PROXMOX_HOST="192.168.0.100"
PROXMOX_USER="root"

# Built Unity client .exe paths — one per build flavor. run_case.py picks the
# matching one based on --flavor dgs|arch|bevy. Use forward slashes or
# double-escaped backslashes on Windows.
CLIENT_EXE_DGS="B:/DGSvsHS/Build/2026-05-22/Client-DGS/DGSvsHS.exe"
CLIENT_EXE_ARCH="B:/DGSvsHS/Build/2026-05-22/Client-Arch/DGSvsHS.exe"
CLIENT_EXE_BEVY="B:/DGSvsHS/Build/2026-05-22/Client-Bevy/DGSvsHS.exe"
CLIENT_EXE_UNREAL="B:/DGSvsHS/Build/Client/Unreal/Windows/UnrealvsHS.exe"
